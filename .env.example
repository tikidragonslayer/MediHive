# Firebase
FIREBASE_PROJECT_ID=medihive-demo
FIRESTORE_EMULATOR_HOST=localhost:8080  # only for local dev
FIREBASE_AUTH_EMULATOR_HOST=localhost:9099  # only for local dev

# Solana
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_NETWORK=devnet

# Anthropic (for MediScribe SOAP generation)
ANTHROPIC_API_KEY=sk-ant-...

# IPFS (Pinata or similar)
IPFS_API_URL=https://api.pinata.cloud
IPFS_API_KEY=
IPFS_API_SECRET=

# Scheduler Security
CRON_SECRET=  # required - validates Cloud Scheduler requests

# Dashboard
NEXT_PUBLIC_FIREBASE_CONFIG={"apiKey":"...","authDomain":"medihive-demo.firebaseapp.com","projectId":"medihive-demo"}
NEXT_PUBLIC_USE_EMULATOR=false

# ASR (Whisper)
WHISPER_SERVER_URL=http://localhost:8000  # local Whisper server on GPU
WHISPER_MODEL=large-v3

# Port
PORT=4000
