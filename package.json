{
  "name": "medihive",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hostable hospital records where the patient holds the keys. FHIR R4 + AI medical scribe + Solana-anchored access control.",
  "license": "AGPL-3.0-or-later",
  "homepage": "https://github.com/tikidragonslayer/MediHive",
  "repository": {
    "type": "git",
    "url": "https://github.com/tikidragonslayer/MediHive.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm test --workspaces --if-present",
    "dev": "npm run dev --workspace=packages/api-server",
    "seed": "npx tsx scripts/seed/index.ts",
    "deploy": "bash scripts/deploy/deploy.sh",
    "lint": "npm run lint --workspaces --if-present",
    "clean": "npx rimraf packages/*/dist",
    "build:programs": "cd packages/vault-programs && anchor build",
    "test:programs": "cd packages/vault-programs && anchor test",
    "build:sdk": "cd packages/vault-sdk && npm run build",
    "build:dashboard": "cd packages/pulse-dashboard && npm run build",
    "dev:dashboard": "cd packages/pulse-dashboard && npm run dev",
    "_comment_postinstall": "Workspaces with file: links resolve at install time, but per-workspace prepare scripts run in parallel — so a consumer can typecheck before its dependency's dist/ is populated. Building producers in topological order from the root postinstall fixes this for both fresh clones and CI.",
    "postinstall": "npm run build --workspace=@medi-hive/vault-driver --workspace=@medi-hive/vault-sdk --workspace=@medi-hive/bridge-core --workspace=@medi-hive/brain-engine --workspace=@medi-hive/local-vault --if-present"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "protobufjs": "^7.5.5",
    "uuid": "^11.0.0",
    "@tootallnate/once": "^3.0.0",
    "fast-xml-parser": "^5.7.0"
  },
  "dependencies": {
    "protobufjs": "^7.5.5"
  }
}
