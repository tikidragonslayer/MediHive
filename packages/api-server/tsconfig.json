{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "declaration": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*"],
  // services/blockchain-sync.ts is unused at runtime and still uses the
  // pre-VaultDriver Solana types via a relative path. Excluded from the
  // build until the full SolanaVaultDriver lands; will be migrated in
  // the same PR that wires Anchor through @medi-hive/vault-driver.
  "exclude": [
    "node_modules",
    "dist",
    "src/services/blockchain-sync.ts"
  ]
}
